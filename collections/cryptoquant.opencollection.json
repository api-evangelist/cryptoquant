            "method": "GET",
            "url": "https://api.cryptoquant.com/v1/btc/exchange-flows/inflow",
            "params": [
              {
                "name": "window",
                "value": "",
                "type": "query",
                "description": "Resolution of the time-series."
              },
              {
                "name": "from",
                "value": "",
                "type": "query",
                "description": "Inclusive start timestamp (RFC3339 or YYYYMMDDTHHMMSS)."
              },
