                "name": "to",
                "value": "",
                "type": "query",
                "description": "Inclusive end timestamp."
              },
              {
                "name": "exchange",
                "value": "",
                "type": "query",
                "description": "Exchange name (e.g. binance, coinbase, kraken, all_exchange)."
              }
